generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}

model SystemField {
  id        Int            @id @default(autoincrement())
  key       String         @unique
  label     String
  type      String
  formula   String?
  dataType  String
  isCustom  Boolean        @default(false)
  createdAt DateTime       @default(now())
  mappings  FieldMapping[]
}

model FieldMapping {
  id            Int         @id @default(autoincrement())
  sourceColumn  String      @unique
  systemFieldId Int
  systemField   SystemField @relation(fields: [systemFieldId], references: [id])
  createdAt     DateTime    @default(now())
}

model SaleRecord {
  id          Int      @id @default(autoincrement())
  year        Int
  month       Int
  store       String
  revenue     Float    @default(0)
  quantity    Int      @default(0)
  checks      Int      @default(0)
  grossProfit Float    @default(0)
  extraData   Json?
  syncedAt    DateTime @default(now())

  @@unique([year, month, store])
}

model SyncLog {
  id         Int      @id @default(autoincrement())
  syncedAt   DateTime @default(now())
  rowsCount  Int
  newCount   Int      @default(0)
  updCount   Int      @default(0)
  status     String
  message    String?
  updates    Json?    // список обновлённых записей { store, year, month }[]
}
