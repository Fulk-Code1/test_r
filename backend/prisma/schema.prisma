generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model SystemField {
  id        Int            @id @default(autoincrement())
  key       String         @unique
  label     String
  type      String
  formula   String?
  dataType  String
  createdAt DateTime       @default(now())
  mappings  FieldMapping[]
}

model FieldMapping {
  id            Int         @id @default(autoincrement())
  sourceColumn  String      @unique
  systemFieldId Int
  systemField   SystemField @relation(fields: [systemFieldId], references: [id])
  createdAt     DateTime    @default(now())
}

// Основная таблица данных — фиксированные колонки
model SaleRecord {
  id          Int      @id @default(autoincrement())
  year        Int
  month       Int
  store       String
  revenue     Float    @default(0)
  quantity    Int      @default(0)
  checks      Int      @default(0)
  grossProfit Float    @default(0)
  syncedAt    DateTime @default(now())
}

model SyncLog {
  id        Int      @id @default(autoincrement())
  syncedAt  DateTime @default(now())
  rowsCount Int
  status    String
  message   String?
}
